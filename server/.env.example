# ── Database ──────────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/victory-journal
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/victory-journal
MONGODB_URI=mongodb://localhost:27017/victory-journal

# ── Auth ──────────────────────────────────────────────────────────────────────
# Long random string — generate one at: https://generate-secret.vercel.app/32
JWT_SECRET=replace-with-a-long-random-secret

# Google OAuth Client ID (from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Dev:        http://localhost:5173
# Production: https://your-app.vercel.app,https://your-custom-domain.com
CLIENT_ORIGIN=http://localhost:5173

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
